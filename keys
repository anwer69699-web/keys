local function isMyBase(plotName)
    local plotsFolder = workspace:FindFirstChild("Plots")
    if not plotsFolder then return false end
    local plot = plotsFolder:FindFirstChild(plotName)
    if not plot then return false end
    local sign = plot:FindFirstChild("PlotSign")
    if sign then
        local yourBase = sign:FindFirstChild("YourBase")
        if yourBase and yourBase:IsA("BillboardGui") then
            return yourBase.Enabled == true
        end
    end
    if sign then
        local owner = sign:FindFirstChild("OwnerName")
        if owner and owner:IsA("TextLabel") then
            if owner.Text == Player.Name or owner.Text == Player.DisplayName then
                return true
            end
        end
    end
    local ownerVal = plot:FindFirstChild("Owner")
    if ownerVal and (ownerVal:IsA("StringValue") or ownerVal:IsA("ObjectValue")) then
        local val = ownerVal:IsA("StringValue") and ownerVal.Value or (ownerVal.Value and ownerVal.Value.Name)
        if val == Player.Name or val == Player.DisplayName then return true end
    end
    return false
end

local function scanPlots()
    local plotsFolder = workspace:FindFirstChild("Plots")
    if not plotsFolder then
        StealSettings.Cache = {}
        return
    end
    local newCache = {}
    for _, plot in ipairs(plotsFolder:GetChildren()) do
        if not plot:IsA("Model") then continue end
        local pods = plot:FindFirstChild("AnimalPodiums")
        if not pods then continue end
        for _, pod in ipairs(pods:GetChildren()) do
            if not pod:IsA("Model") then continue end
            local base = pod:FindFirstChild("Base")
            if not base then continue end
            local spawnObj = base:FindFirstChild("Spawn")
            if not spawnObj then continue end
            local attach = spawnObj:FindFirstChild("PromptAttachment")
            if not attach then continue end
            for _, v in ipairs(attach:GetChildren()) do
                if v:IsA("ProximityPrompt") and v.Enabled and v.MaxActivationDistance >= 5 then
                    local pivot = pod:GetPivot()
                    local uid = plot.Name .. "_" .. pod.Name
                    table.insert(newCache, {
                        plot = plot.Name,
                        slot = pod.Name,
                        pos = pivot.Position,
                        uid = uid,
                        promptObj = v,
                    })
                    StealSettings.Prompts[uid] = v
                end
            end
        end
    end
    StealSettings.Cache = newCache
end

local function getNearest()
    if not isAlive() then return nil end
    local root = getHRP()
    if not root then return nil end
    local nearest = nil
    local minDist = StealSettings.Radius
    local myPos = root.Position
    for _, data in ipairs(StealSettings.Cache) do
        local dist = (myPos - data.pos).Magnitude
        if dist < minDist then
            minDist = dist
            nearest = data
        end
    end
    return nearest
end

local function getPrompt(data)
    if not data then return nil end
    local cached = StealSettings.Prompts[data.uid]
    if cached and cached.Parent and cached.Enabled then return cached end
    local plotsFolder = workspace:FindFirstChild("Plots")
    if not plotsFolder then return nil end
    local plot = plotsFolder:FindFirstChild(data.plot)
    if not plot then return nil end
    local pods = plot:FindFirstChild("AnimalPodiums")
    if not pods then return nil end
    local pod = pods:FindFirstChild(data.slot)
    if not pod then return nil end
    local base = pod:FindFirstChild("Base")
    if not base then return nil end
    local spawnObj = base:FindFirstChild("Spawn")
    if not spawnObj then return nil end
    local attach = spawnObj:FindFirstChild("PromptAttachment")
    if not attach then return nil end
    for _, v in ipairs(attach:GetChildren()) do
        if v:IsA("ProximityPrompt") and v.Enabled then
            StealSettings.Prompts[data.uid] = v
            return v
        end
    end
    return nil
end

local function executeStealInstant(prompt)
    if not prompt or not prompt.Parent then return end
    local uid = tostring(prompt)

    if StealRunning[uid] then return end

    if StealSettings.Cooldowns[uid] and tick() - StealSettings.Cooldowns[uid] < 0.05 then
        return
    end

    StealRunning[uid] = true
    StealSettings.Cooldowns[uid] = tick()

    task.spawn(function()
        pcall(function()
            if fireproximityprompt then
                fireproximityprompt(prompt, 0)
            elseif prompt.InputHoldBegin then
                prompt:InputHoldBegin()
                task.wait(StealSettings.Duration)
                prompt:InputHoldEnd()
                prompt:InputTriggerBegin()
                task.wait(0.05)
                prompt:InputTriggerEnd()
            else
                if getconnections then
                    local ok1, holdConns = pcall(function() return getconnections(prompt.PromptButtonHoldBegan) end)
                    local ok2, triggerConns = pcall(function() return getconnections(prompt.Triggered) end)

                    if ok1 and type(holdConns) == "table" then
                        for _, c in ipairs(holdConns) do
                            if type(c) == "table" and type(c.Function) == "function" then
                                pcall(function() task.spawn(c.Function) end)
                            end
                        end
                    end

                    local startTime = tick()
                    while tick() - startTime < StealSettings.Duration do
                        if ProgressBarFill and ProgressBarFill.Parent then
                            local prog = (tick() - startTime) / StealSettings.Duration
                            Services.TweenService:Create(ProgressBarFill, TweenInfo.new(0.02), {
                                Size = UDim2.new(math.clamp(prog, 0, 1), 0, 1, 0)
                            }):Play()
                        end
                        task.wait(0.02)
                    end

                    if ok2 and type(triggerConns) == "table" then
                        for _, c in ipairs(triggerConns) do
                            if type(c) == "table" and type(c.Function) == "function" then
                                pcall(function() task.spawn(c.Function) end)
                            end
                        end
                    end
                end
            end

            task.wait(0.05)
            if ProgressBarFill and ProgressBarFill.Parent then
                Services.TweenService:Create(ProgressBarFill, TweenInfo.new(0.1), {
                    Size = UDim2.new(0, 0, 1, 0)
                }):Play()
            end
        end)

        task.wait(0.1)
        StealRunning[uid] = nil
    end)
end

local AntiRagdollEnabled = false
local ARConns = {}

local function setupAntiRagdollForChar()
    if not AntiRagdollEnabled then return end
    for _, c in pairs(ARConns) do
        pcall(function() c:Disconnect() end)
    end
    ARConns = {}

    local char = Player.Character
    if not char then return end
    local humanoid = char:WaitForChild("Humanoid")
    local root = char:WaitForChild("HumanoidRootPart")
    local animator = humanoid:WaitForChild("Animator")

    pcall(function() humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false) end)
    pcall(function() humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false) end)
    pcall(function() humanoid:SetStateEnabled(Enum.HumanoidStateType.GettingUp, false) end)

    local recovering = false
    local lastVelocity = Vector3.zero

    local BAD_STATES = {
        [Enum.HumanoidStateType.Physics] = true,
        [Enum.HumanoidStateType.Ragdoll] = true,
        [Enum.HumanoidStateType.FallingDown] = true,
        [Enum.HumanoidStateType.GettingUp] = true,
    }

    local function cleanConstraints()
        if not char or not char.Parent then return end
        for _, obj in pairs(char:GetDescendants()) do
            if obj:IsA("BallSocketConstraint") or obj:IsA("NoCollisionConstraint") or obj:IsA("HingeConstraint") then
                obj:Destroy()
            elseif obj:IsA("Attachment") and (obj.Name == "A" or obj.Name == "B") then
                obj:Destroy()
            elseif obj:IsA("BodyVelocity") or obj:IsA("BodyPosition") or obj:IsA("BodyGyro") then
                obj:Destroy()
            elseif obj:IsA("Motor6D") then
                obj.Enabled = true
            end
        end
        if animator and animator.Parent then
            for _, track in pairs(animator:GetPlayingAnimationTracks()) do
                local name = (track.Animation and track.Animation.Name or ""):lower()
                if name:find("rag") or name:find("fall") or name:find("hurt") or name:find("down") then
                    track:Stop(0)
                end
            end
        end
    end

    local function reEnableControls()
        pcall(function()
            require(Player:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule")):GetControls():Enable()
        end)
    end

    local function startRecovery()
        if recovering then return end
        recovering = true
        task.spawn(function()
            local endTime = tick() + 0.5
            while tick() < endTime do
                if not AntiRagdollEnabled then break end
                if not humanoid or not humanoid.Parent or not root or not root.Parent then break end
                if BAD_STATES[humanoid:GetState()] then
                    cleanConstraints()
                    pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Running) end)
                    local vel = root.Velocity
                    if vel.Magnitude > 30 then
                        root.Velocity = Vector3.new(0, math.min(vel.Y, 5), 0)
                    end
                    workspace.CurrentCamera.CameraSubject = humanoid
                    reEnableControls()
                end
                pcall(function() humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false) end)
                pcall(function() humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false) end)
                task.wait(0.02)
            end
            recovering = false
        end)
    end

    table.insert(ARConns, humanoid.StateChanged:Connect(function(_, newState)
        if BAD_STATES[newState] then startRecovery() end
    end))

    table.insert(ARConns, Services.RunService.Heartbeat:Connect(function()
        if not AntiRagdollEnabled then return end
        if not humanoid or not humanoid.Parent or not root or not root.Parent then return end
        if BAD_STATES[humanoid:GetState()] then
            startRecovery()
            local vel = root.Velocity
            local velDif = (vel - lastVelocity).Magnitude
            if velDif > 50 and vel.Magnitude > 20 then
                root.Velocity = Vector3.new(0, math.min(vel.Y, 5), 0)
            end
        end
        lastVelocity = root.Velocity
    end))

    table.insert(ARConns, char.DescendantAdded:Connect(function(obj)
        if obj:IsA("BallSocketConstraint") or obj:IsA("NoCollisionConstraint") or obj:IsA("HingeConstraint") or obj:IsA("BodyVelocity") or obj:IsA("BodyPosition") or obj:IsA("BodyGyro") then
            task.defer(function()
                if obj and obj.Parent then obj:Destroy() end
            end)
        elseif obj:IsA("Motor6D") then
            task.defer(function()
                if obj and obj.Parent then obj.Enabled = true end
            end)
        end
    end))

    reEnableControls()
    cleanConstraints()
end

