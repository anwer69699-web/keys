local function findNearestPlayer()
    local c = Player.Character
    if not c then return nil end
    local h = c:FindFirstChild("HumanoidRootPart")
    if not h then return nil end
    local pos = h.Position
    local nearest, dist = nil, math.huge
    for _, p in ipairs(Services.Players:GetPlayers()) do
        if p ~= Player and p.Character then
            local oh = p.Character:FindFirstChild("HumanoidRootPart")
            if oh then
                local d = (pos - oh.Position).Magnitude
                if d < dist then
                    dist = d
                    nearest = p
                end
            end
        end
    end
    return nearest
end

local function startLock()
    if LockConn then return end
    LockConn = Services.RunService.Heartbeat:Connect(function()
        if not LockActive then return end
        local c = Player.Character
        if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        local hum = c:FindFirstChildOfClass("Humanoid")
        if not h or not hum then return end
        local target = findNearestPlayer()
        if not target or not target.Character then
            h.Velocity = Vector3.new(0, h.Velocity.Y, 0)
            return
        end
        local eh = target.Character:FindFirstChild("HumanoidRootPart")
        if not eh then return end
        local pos = h.Position
        local targetPos = eh.Position
        local dir = targetPos - pos
        local flatDir = Vector3.new(dir.X, 0, dir.Z)
        local flatDist = flatDir.Magnitude
        local spd = 55
        if flatDist > 3 then
            local moveDir = flatDir.Unit
            h.Velocity = Vector3.new(moveDir.X * spd, h.Velocity.Y, moveDir.Z * spd)
        elseif flatDist > 0.5 then
            local moveDir = flatDir.Unit
            h.Velocity = Vector3.new(moveDir.X * spd * 0.3, h.Velocity.Y, moveDir.Z * spd * 0.3)
        else
            h.Velocity = Vector3.new(eh.Velocity.X * 0.5, h.Velocity.Y, eh.Velocity.Z * 0.5)
        end
        local yDiff = targetPos.Y - pos.Y
        if math.abs(yDiff) > 1 then
            local yVel = math.clamp(yDiff * 3, -40, 40)
            h.Velocity = Vector3.new(h.Velocity.X, yVel, h.Velocity.Z)
        end
    end)
end

local function stopLock()
    if LockConn then
        LockConn:Disconnect()
        LockConn = nil
    end
    local hrp = getHRP()
    if hrp then
        hrp.Velocity = Vector3.new(0, hrp.Velocity.Y, 0)
    end
end

