local function makeDraggable(btn, clickHandler)
    local dragging = false
    local dragConn = nil
    local moveConn = nil
    local dragStart = Vector3.zero
    local startPos = UDim2.new()
    local startMousePos = Vector3.zero
    local totalDragDist = 0

    btn.Active = true

    btn.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            totalDragDist = 0
            dragStart = input.Position
            startMousePos = input.Position
            startPos = btn.Position
            playSFX("dragStart")

            if dragConn then dragConn:Disconnect() end
            if moveConn then moveConn:Disconnect() end

            dragConn = Services.UserInputService.InputEnded:Connect(function(endInput)
                if dragging and (endInput.UserInputType == Enum.UserInputType.MouseButton1 or endInput.UserInputType == Enum.UserInputType.Touch) then
                    local endDist = (endInput.Position - dragStart).Magnitude
                    if totalDragDist < 10 and endDist < 10 then
                        if clickHandler then clickHandler() end
                    end
                    dragging = false
                    if dragConn then dragConn:Disconnect(); dragConn = nil end
                    if moveConn then moveConn:Disconnect(); moveConn = nil end
                end
            end)

            moveConn = Services.UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    local delta = input.Position - startMousePos
                    totalDragDist = totalDragDist + delta.Magnitude
                    btn.Position = UDim2.new(
                        startPos.X.Scale, startPos.X.Offset + delta.X,
                        startPos.Y.Scale, startPos.Y.Offset + delta.Y
                    )
                end
            end)
        end
    end)
end

