local function submitKey()
    local enteredKey = KeyInputBox.Text
    if enteredKey == "" then return end

    if enteredKey == TRIAL_KEY then
        isTrialUser = true
        KeyStatusLabel.Text = "Trial: 90s only"
        KeyStatusLabel.TextColor3 = Color3.fromRGB(255, 200, 80)
        task.wait(1)
        keyEvent:Fire(true)
        return
    end

    for key, uid in pairs(RealKeys) do
        if enteredKey == key then
            if myUserId == uid then
                KeyStatusLabel.Text = "Key accepted"
                KeyStatusLabel.TextColor3 = TH.green
                task.wait(0.5)
                keyEvent:Fire(true)
                return
            else
                KeyStatusLabel.Text = "Key is not for your account"
                KeyStatusLabel.TextColor3 = TH.danger
                return
            end
        end
    end

    attemptsRemaining = attemptsRemaining - 1
    if attemptsRemaining <= 0 then
        AttemptsLabel.Text = "Attempts remaining: 0"
        KeyStatusLabel.Text = "Locked! Too many attempts."
        KeyStatusLabel.TextColor3 = TH.danger
        KeySubmitBtn.Active = false
        KeyInputBox.Active = false
        KeyInputBox.TextEditable = false
        task.wait(2)
        keyEvent:Fire(false)
    else
        AttemptsLabel.Text = "Attempts remaining: " .. tostring(attemptsRemaining)
        KeyStatusLabel.Text = "Invalid key"
        KeyStatusLabel.TextColor3 = TH.danger
    end
end

