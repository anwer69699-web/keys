local hookSuccess = false
pcall(function()
    if type(getrawmetatable) ~= "function" then return end
    if type(newcclosure) ~= "function" then return end
    if type(getnamecallmethod) ~= "function" then return end
    if type(setreadonly) ~= "function" then return end

    local mt = getrawmetatable(game)
    if not mt then return end
    local oldNC = mt.__namecall
    if type(oldNC) ~= "function" then return end

    setreadonly(mt, false)

    mt.__namecall = newcclosure(function(self, ...)
        local args = {...}
        local method = getnamecallmethod()

        if method == "FindFirstChildOfClass" and self == Services.CoreGui then
            local arg = args[1]
            if type(arg) == "string" and arg == "ScreenGui" then
                local res = oldNC(self, unpack(args))
                if res == GuiRef then return nil end
                return res
            end
        end

        if method == "GetChildren" and self == Services.CoreGui then
            local res = oldNC(self, unpack(args))
            if type(res) == "table" then
                local filtered = {}
                for _, v in ipairs(res) do
                    if v ~= GuiRef then
                        table.insert(filtered, v)
                    end
                end
                return filtered
            end
            return res
        end

        return oldNC(self, unpack(args))
    end)

    setreadonly(mt, true)
    hookSuccess = true
end)

