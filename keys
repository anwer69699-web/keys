    local ModeKeyLabel = makeStyledLabel(FrameHotkey, 8, ky0 + kGap * 5, kLabelW, 20, "Mode:", 10)
    local ModeKeyBtn = makeBtn(FrameHotkey, 86, ky0 + kGap * 5, kBtnW, 20, Hotkeys.ModeCycle, 10)

    HotkeyLabels = { Left = LeftKeyBtn, Right = RightKeyBtn, Lock = LockKeyBtn, Drop = DropKeyBtn, Speed = SpeedKeyBtn, Mode = ModeKeyBtn }

    local function setupHotkeyButton(btn, keyType)
        btn.MouseButton1Click:Connect(function()
            if listeningForHotkey then return end
            listeningForHotkey = keyType
            btn.Text = "..."
            setBtnBg(btn, TH.redBright)

            local connection
            connection = Services.UserInputService.InputBegan:Connect(function(input, gameProcessed)
                if gameProcessed then return end
                local keyName = input.KeyCode.Name
                if keyName and keyName ~= "Unknown" then
                    Hotkeys[keyType] = keyName
                    btn.Text = keyName
                    setBtnBg(btn, TH.rowBg)
                end
                connection:Disconnect()
                listeningForHotkey = nil
            end)

            task.delay(5, function()
                if listeningForHotkey == keyType then
                    btn.Text = Hotkeys[keyType]
                    setBtnBg(btn, TH.rowBg)
                    listeningForHotkey = nil
                    if connection then connection:Disconnect() end
                end
            end)
        end)
    end

    setupHotkeyButton(LeftKeyBtn, "AutoLeft")
    setupHotkeyButton(RightKeyBtn, "AutoRight")
    setupHotkeyButton(LockKeyBtn, "Lock")
    setupHotkeyButton(DropKeyBtn, "Drop")
    setupHotkeyButton(SpeedKeyBtn, "SpeedBoost")
    setupHotkeyButton(ModeKeyBtn, "ModeCycle")

    makeFrameDraggableByHeader(FrameHotkey, FrameHotkey)

    Services.UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if listeningForHotkey then return end
        local keyName = input.KeyCode.Name

        if keyName == Hotkeys.AutoLeft then
            if BtnL_Ref then
                pcall(function()
                    task.wait(0.1)
                    if getconnections then
                        for _, conn in pairs(getconnections(BtnL_Ref.MouseButton1Click)) do
                            pcall(function() conn:Fire() end)
                        end
                    end
                end)
            end
        elseif keyName == Hotkeys.AutoRight then
            if BtnR_Ref then
                pcall(function()
                    task.wait(0.1)
                    if getconnections then
                        for _, conn in pairs(getconnections(BtnR_Ref.MouseButton1Click)) do
                            pcall(function() conn:Fire() end)
                        end
                    end
                end)
            end
        elseif keyName == Hotkeys.Lock then
            if LockBtn_Ref then
                pcall(function()
                    task.wait(0.1)
                    doToggleLock()
                end)
            end
        elseif keyName == Hotkeys.Drop then
            if DropBtn_Ref then
                pcall(function()
                    task.wait(0.1)
                    doDropBrainrot()
                end)
            end
        elseif keyName == Hotkeys.SpeedBoost then
            pcall(function()
                task.wait(0.1)
                toggleSpeedBoost()
                if SpeedBoostActive then
                    SpeedBoostBtn.Text = "Speed Boost: ON"
                    setBtnBg(SpeedBoostBtn, TH.redDark)
                else
                    SpeedBoostBtn.Text = "Speed Boost: OFF"
                    setBtnBg(SpeedBoostBtn, TH.rowBg)
                end
            end)
        elseif keyName == Hotkeys.ModeCycle then
            pcall(function()
                task.wait(0.1)
                local modes = {"NORMAL", "DESYNC", "LAGGER"}
                local currentIdx = 1
                for i, m in ipairs(modes) do
                    if m == (_G.NuxusBooster.Mode or "NORMAL") then
                        currentIdx = i
                        break
                    end
                end
                local nextIdx = (currentIdx % #modes) + 1
                updateModeButtons(modes[nextIdx])
            end)
        end
    end)
end


