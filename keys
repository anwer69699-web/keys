        end
    end
end)

local VisualActive = false

VisualToggle.MouseButton1Click:Connect(function()
    VisualActive = not VisualActive
    if VisualActive then
        createRadiusBall()
        VisualToggle.Text = "VISUAL: ON"
        setBtnBg(VisualToggle, TH.redDark)
    else
        if RadiusBall then
            pcall(function() RadiusBall:Destroy() end)
            RadiusBall = nil
        end
        VisualToggle.Text = "VISUAL: OFF"
        setBtnBg(VisualToggle, TH.rowBg)
    end
end)

local RadiusBallConn = Services.RunService.Heartbeat:Connect(function()
    if VisualActive and RadiusBall and RadiusBall.Parent then
        updateRadiusBall()
    end
end)

task.spawn(function()
    while Gui and Gui.Parent do
        scanPlots()
        task.wait(2)
    end
end)


CloseAllBtn.MouseButton1Click:Connect(function()
    scriptAlive = false
    if FPSConn then FPSConn:Disconnect(); FPSConn = nil end
    if AutoStealConn then
        AutoStealConn:Disconnect()
        AutoStealConn = nil
    end
    stopStealPath()
    currentPathSide = nil
    if BtnL_Ref and BtnL_Ref.Parent then setBtnBg(BtnL_Ref, TH.rowBg) end
    if BtnR_Ref and BtnR_Ref.Parent then setBtnBg(BtnR_Ref, TH.rowBg) end
    disableAntiRagdoll()
    deactivateJump()
    if SpeedBoostActive then
        SpeedBoostActive = false
        local hum = getHumanoid()
        if hum then hum.WalkSpeed = savedWalkSpeed end
        if SpeedBoostConn then
            SpeedBoostConn:Disconnect()
            SpeedBoostConn = nil
        end
    end
    pcall(function()
        if MusicSound2 then
            MusicSound2:Stop()
            MusicSound2:Destroy()
        end
    end)
    LockActive = false
    stopLock()
    if LockBtn_Ref and LockBtn_Ref.Parent then
        LockBtn_Ref.Text = "Lock"
        setBtnBg(LockBtn_Ref, TH.rowBg)
    end
    if UnwalkActive then
        stopUnwalk()
    end
    VisualActive = false
    if RadiusBall then
        pcall(function() RadiusBall:Destroy() end)
        RadiusBall = nil
    end
    if RadiusBallConn then RadiusBallConn:Disconnect(); RadiusBallConn = nil end
    DropActive = false
    for _, c in ipairs(DropConns) do
        pcall(function() if typeof(c) == "RBXScriptConnection" then c:Disconnect() end end)
    end
    DropConns = {}
    pcall(function()
        if WatermarkGui and WatermarkGui.Parent then WatermarkGui:Destroy() end
    end)
    pcall(function()
        if SoundParent and SoundParent.Parent then SoundParent:Destroy() end
    end)
    Gui:Destroy()
    GuiRef = nil
end)

