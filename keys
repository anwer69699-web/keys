local function pathMoveToPoint(hrp, targetPos, nextPos, isSteal, myPathId)
    local char = hrp.Parent
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local conn = nil
    local reached = false

    conn = Services.RunService.Heartbeat:Connect(function()
        if not pathActive or reached or pathRunLoopId ~= myPathId then
            if conn then conn:Disconnect() end
            if hum then hum:Move(Vector3.zero, false) end
            return
        end
        if not hrp or not hrp.Parent then
            if conn then conn:Disconnect() end
            return
        end
        if hum and hum:GetState() == Enum.HumanoidStateType.Physics then return end

        local speed = isSteal and PathSpeedSettings.StealSpeed or PathSpeedSettings.NormalSpeed
        local pos = hrp.Position
        local target = Vector3.new(targetPos.X, pos.Y, targetPos.Z)
        local dir = target - pos
        local dist = dir.Magnitude
        local stopDist = math.clamp(PATH_BASE_STOP - dist * 0.04, PATH_MIN_STOP, PATH_BASE_STOP)

        if dist <= stopDist then
            reached = true
            if conn then conn:Disconnect() end
            if hum then hum:Move(Vector3.zero, false) end
            return
        end

        local moveDir = dir.Unit
        if nextPos then
            local nextDir = (Vector3.new(nextPos.X, pos.Y, nextPos.Z) - pos).Unit
            moveDir = (moveDir + nextDir * PATH_NEXT_POINT_BIAS).Unit
        end
        if lastFlatVel.Magnitude > 0.1 then
            moveDir = (moveDir * (1 - PATH_SMOOTH_FACTOR) + lastFlatVel.Unit * PATH_SMOOTH_FACTOR).Unit
        end

        if hum then hum:Move(moveDir, false) end
        local vel = Vector3.new(moveDir.X * speed, hrp.Velocity.Y, moveDir.Z * speed)
        hrp.Velocity = vel
        lastFlatVel = Vector3.new(vel.X, 0, vel.Z)
    end)

    while pathActive and hrp and hrp.Parent and not reached and pathRunLoopId == myPathId do
        Services.RunService.Heartbeat:Wait()
    end

    if conn and conn.Connected then
        conn:Disconnect()
    end
end

local function runStealPath(path)
    local myPathId = pathRunLoopId
    local char = Player.Character
    if not char then return end
    local hrpLocal = char:FindFirstChild("HumanoidRootPart")
    if not hrpLocal then return end
    for i, p in ipairs(path) do
        if not pathActive or pathRunLoopId ~= myPathId then return end
        local nextP = path[i + 1] and path[i + 1].pos
        pathMoveToPoint(hrpLocal, p.pos, nextP, i > 2, myPathId)
        if not pathActive or pathRunLoopId ~= myPathId then return end
        task.wait()
    end
end

