        end)
    end
end

local function playHover()
    local now = tick()
    if now - lastHoverTime < 0.08 then return end
    lastHoverTime = now
    playSFX("hover")
end

local function addBtnEffects(btn)
    local origBgTransparency = (btn:FindFirstChild("BG") and btn.BG.BackgroundTransparency) or 0.5
    btn.MouseEnter:Connect(function()
        playHover()
        local bg = btn:FindFirstChild("BG")
        if bg then
            origBgTransparency = bg.BackgroundTransparency
            Services.TweenService:Create(bg, TweenInfo.new(0.15), {
                BackgroundTransparency = math.max(0, origBgTransparency - 0.2)
            }):Play()
        end
        Services.TweenService:Create(btn, TweenInfo.new(0.1, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            TextTransparency = 0
        }):Play()
    end)
    btn.MouseLeave:Connect(function()
        local bg = btn:FindFirstChild("BG")
        if bg then
            Services.TweenService:Create(bg, TweenInfo.new(0.2), {
                BackgroundTransparency = origBgTransparency
            }):Play()
        end
    end)
end
local function createAnimatedBorder(parent, speed, thickness)
    speed = speed or 1.5
    thickness = thickness or 2
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = thickness
    stroke.Color = Color3.new(1, 1, 1)
    stroke.Transparency = 0
    stroke.Parent = parent
    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, TH.borderDark),
        ColorSequenceKeypoint.new(0.15, TH.redGlow),
        ColorSequenceKeypoint.new(0.3, TH.borderDark),
        ColorSequenceKeypoint.new(0.5, TH.red),
        ColorSequenceKeypoint.new(0.7, TH.borderDark),
        ColorSequenceKeypoint.new(0.85, TH.redBright),
        ColorSequenceKeypoint.new(1, TH.borderDark),
    })
    grad.Rotation = 0
    grad.Parent = stroke
    task.spawn(function()
        while parent and parent.Parent do
            grad.Rotation = (grad.Rotation + speed) % 360
            task.wait(0.033)
        end
    end)
    return stroke
end

local function createAnimatedTextGradient(textLabel, speed)
    speed = speed or 2
    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, TH.redDark),
        ColorSequenceKeypoint.new(0.25, TH.redBright),
        ColorSequenceKeypoint.new(0.5, TH.redGlow),
        ColorSequenceKeypoint.new(0.75, TH.redBright),
        ColorSequenceKeypoint.new(1, TH.redDark),
    })
    grad.Rotation = 0
    grad.Parent = textLabel
    task.spawn(function()
        while textLabel and textLabel.Parent do
            grad.Rotation = (grad.Rotation + speed) % 360
            task.wait(0.033)
        end
    end)
    return grad
end

